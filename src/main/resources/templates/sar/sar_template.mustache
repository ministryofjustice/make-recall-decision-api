<h1 class="title">Consider a Recall</h1>
<br>
{{#.}}
    <h3>Recommendations</h3>
    <br>
    {{#recommendations}}
        <table class="data-table">
            <tr>
                <td class="data-column-35">Created by surname</td>
                <td class="data-column-30">Created date</td>
            </tr>
            <tr>
                <td>{{ getUserLastName createdBy }}</td>
                <td>{{ optionalValue (formatDate createdDate) }}</td>
            </tr>
        </table>
        <br>
        <h5>Recall considered list</h5>
        {{#recallConsideredList}}
            <table class="data-table">
                <tr>
                    <td class="data-column-35">Date created</td>
                    <td class="data-column-30">Surname</td>
                    <td class="data-column-35"></td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate createdDate) }}</td>
                    <td>{{ getUserLastName userId }}</td>
                    <td></td>
                </tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-100">Details</td></tr>
                <tr><td>{{ optionalValue recallConsideredDetail }}</td></tr>
            </table>
        {{/recallConsideredList}}
        {{^recallConsideredList}}
            <p>No Data Held</p>
        {{/recallConsideredList}}
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-20">Recall type</td>
                <td class="data-column-80">Details</td>
            </tr>
            <tr>
                <td>{{ optionalValue recallType.selected.value }}</td>
                <td>{{ optionalValue recallType.selected.details }}</td>
            </tr>
        </table>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-25">Manager recall decision</td>
                <td class="data-column-25">Details</td>
                <td class="data-column-25">Created by surname</td>
                <td class="data-column-25">Created date</td>
            </tr>
            <tr>
                <td>{{ optionalValue managerRecallDecision.selected.value }}</td>
                <td>{{ optionalValue managerRecallDecision.selected.details }}</td>
                <td>{{ getUserLastName managerRecallDecision.createdBy }}</td>
                <td>{{ optionalValue (formatDate managerRecallDecision.createdDate) }}</td>
            </tr>
        </table>
        <br>
        <h5>Consideration Rationale</h5>
        {{#considerationRationale}}
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Date created</td>
                    <td class="data-column-25">Time created</td>
                    <td class="data-column-25">Created by surname</td>
                    <td class="data-column-25">Sensitive</td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate createdDate) }}</td>
                    <td>{{ optionalValue (formatDate createdTime) }}</td>
                    <td>{{ getUserLastName createdBy }}</td>
                    <td>{{ convertBoolean sensitive }}</td>
                </tr>
            </table>
        {{/considerationRationale}}
        {{^considerationRationale}}
            <p>No Data Held</p>
        {{/considerationRationale}}
        <br>
        <h5>Custody status</h5>
        {{#custodyStatus}}
            <table class="data-table">
                <tr>
                    <td class="data-column-35">Selected</td>
                    <td class="data-column-65">Details</td>
                </tr>
                <tr>
                    <td>{{ convertBoolean selected }}</td>
                    <td>{{ optionalValue details }}</td>
                </tr>
            </table>
        {{/custodyStatus}}
        {{^custodyStatus}}
            <p>No Data Held</p>
        {{/custodyStatus}}
        <br>
        <h5>Local police contact</h5>
        {{#localPoliceContact}}
            <table class="data-table">
                <tr>
                    <td class="data-column-100">Contact surname</td>
                </tr>
                <tr>
                    <td>{{ getUserLastName contactName }}</td>
                </tr>
            </table>
        {{/localPoliceContact}}
        {{^localPoliceContact}}
            <p>No Data Held</p>
        {{/localPoliceContact}}
        <br>
        <br>
        {{#sentenceGroup}}
        <table class="data-table">
            <tr><td class="data-column-20">Sentence group</td></tr>
            <tr><td>{{ optionalValue sentenceGroup }}</td></tr>
        </table>
        {{/sentenceGroup}}
        <table class="data-table">
            <tr>
                <td class="data-column-25">Emergency recall</td>
                <td class="data-column-25">Indeterminate sentence</td>
                <td class="data-column-25">Extended sentence</td>
                <td class="data-column-25">Active custodial conviction count</td>
            </tr>
            <tr>
                <td>{{ convertBoolean isThisAnEmergencyRecall }}</td>
                <td>{{ convertBoolean isIndeterminateSentence }}</td>
                <td>{{ convertBoolean isExtendedSentence }}</td>
                <td>{{ optionalValue activeCustodialConvictionCount }}</td>
            </tr>
        </table>

        <table class="data-table">
            <tr><td class="data-column-100">Response to probation</td></tr>
            <tr><td>{{ optionalValue responseToProbation }}</td></tr>
        </table>

        <table class="data-table">
            <tr><td class="data-column-100">Thoughts leading to recall</td></tr>
            <tr><td>{{ optionalValue thoughtsLeadingToRecall }}</td></tr>
        </table>

        <table class="data-table">
            <tr><td class="data-column-100">Trigger leading to recall</td></tr>
            <tr><td>{{ optionalValue triggerLeadingToRecall }}</td></tr>
        </table>

        <table class="data-table">
            <tr><td class="data-column-100">What led to recall</td></tr>
            <tr><td>{{ optionalValue whatLedToRecall }}</td></tr>
        </table>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-50">Has victims in contact scheme</td>
                <td class="data-column-50">Date VLO informed</td>
            </tr>
            <tr>
                <td>{{ optionalValue hasVictimsInContactScheme.selected }}</td>
                <td>{{ optionalValue (formatDate dateVloInformed) }}</td>
            </tr>
        </table>
        <br>
        <table class="data-table">
            <tr><td class="data-column-20">Indeterminate sentence type</td></tr>
            <tr><td>{{ optionalValue indeterminateSentenceType.selected }}</td></tr>
        </table>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-25">Has arrest issues</td>
                <td class="data-column-75">Details</td>
            </tr>
            <tr>
                <td>{{ convertBoolean hasArrestIssues.selected }}</td>
                <td>{{ optionalValue hasArrestIssues.details }}</td>
            </tr>
        </table>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-25">Has contraband risk</td>
                <td class="data-column-75">Details</td>
            </tr>
            <tr>
                <td>{{ convertBoolean hasContrabandRisk.selected }}</td>
                <td>{{ optionalValue hasContrabandRisk.details }}</td>
            </tr>
        </table>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Status</td>
                <td class="data-column-30">Region</td>
            </tr>
            <tr>
                <td>{{ optionalValue status }}</td>
                <td>{{ optionalValue region }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Last Decision not to recall letter A downloaded</td>
                <td class="data-column-30">Review practitioners concerns</td>
                <td class="data-column-35">ODM surname</td>
            </tr>
            <tr>
                <td>{{ optionalValue (formatDate lastDntrLetterADownloadDateTime) }}</td>
                <td>{{ convertBoolean reviewPractitionersConcerns }}</td>
                <td>{{ getUserLastName odmName }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Senior Probation Officer recall type</td>
                <td class="data-column-35">Review offender profile</td>
            </tr>
            <tr>
                <td>{{ optionalValue spoRecallType }}</td>
                <td>{{ convertBoolean reviewOffenderProfile }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Explain the decision</td>
                <td class="data-column-35">Last modified by surname</td>
                <td class="data-column-30">Last modified</td>
            </tr>
            <tr>
                <td>{{ convertBoolean explainTheDecision }}</td>
                <td>{{ getUserLastName lastModifiedBy }}</td>
                <td>{{ optionalValue (formatDate lastModifiedDate) }}</td>
            </tr>
        </table>
        <table class="data-table">
            <tr><td class="data-column-100">Senior Probation Officer recall rationale</td></tr>
            <tr><td>{{ optionalValue spoRecallRationale }}</td></tr>
        </table>

        <table class="data-table">
            <tr><td class="data-column-100">Senior Probation Officer cancel recommendation rationale</td></tr>
            <tr><td>{{ optionalValue spoCancelRecommendationRationale }}</td></tr>
        </table>

        <table class="data-table">
            <tr><td class="data-column-100">Senior Probation Officer delete recommendation rationale</td></tr>
            <tr><td>{{ optionalValue spoDeleteRecommendationRationale }}</td></tr>
        </table>

        <h5>Person on probation</h5>
        {{#personOnProbation}}
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Name</td>
                    <td class="data-column-25">First name</td>
                    <td class="data-column-25">Middle names</td>
                    <td class="data-column-25">Surname</td>
                </tr>
                <tr>
                    <td>{{ optionalValue name }}</td>
                    <td>{{ optionalValue firstName }}</td>
                    <td>{{ optionalValue middleNames }}</td>
                    <td>{{ optionalValue surname }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Gender</td>
                    <td class="data-column-25">Ethnicity</td>
                    <td class="data-column-25">Date of birth</td>
                    <td class="data-column-25">Primary language</td>
                </tr>
                <tr>
                    <td>{{ optionalValue gender }}</td>
                    <td>{{ optionalValue ethnicity }}</td>
                    <td>{{ optionalValue (formatDate dateOfBirth) }}</td>
                    <td>{{ optionalValue primaryLanguage }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">CRO number</td>
                    <td class="data-column-25">Most recent prisoner number</td>
                    <td class="data-column-25">NOMS number</td>
                    <td class="data-column-25">PNC number</td>
                </tr>
                <tr>
                    <td>{{ optionalValue croNumber }}</td>
                    <td>{{ optionalValue mostRecentPrisonerNumber }}</td>
                    <td>{{ optionalValue nomsNumber }}</td>
                    <td>{{ optionalValue pncNumber }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-20">Has been reviewed</td>
                    <td class="data-column-20">Multi-agency Public Protection Arrangements level</td>
                    <td class="data-column-20">Multi-agency Public Protection Arrangements last updated date</td>
                    <td class="data-column-20">Multi-agency Public Protection Arrangements category</td>
                    <td class="data-column-20">Multi-agency Public Protection Arrangements reviewed</td>
                </tr>
                <tr>
                    <td>{{ convertBoolean hasBeenReviewed }}</td>
                    {{#mappa}}
                        <td>{{ optionalValue level }}</td>
                        <td>{{ optionalValue (formatDate lastUpdatedDate) }}</td>
                        <td>{{ optionalValue category }}</td>
                        <td>{{ convertBoolean hasBeenReviewed }}</td>
                    {{/mappa}}
                </tr>
            </table>
            <p><b>Addresses</b></p>
            {{#addresses}}
                <table class="data-table">
                    <tr>
                        <td class="data-column-50">Line 1</td>
                        <td class="data-column-50">Line 2</td>
                    </tr>
                    <tr>
                        <td>{{ optionalValue line1 }}</td>
                        <td>{{ optionalValue line2 }}</td>
                    </tr>
                </table>
                <table class="data-table">
                    <tr>
                        <td class="data-column-50">Town</td>
                        <td class="data-column-25">Postcode</td>
                        <td class="data-column-25">No fixed abode</td>
                    </tr>
                    <tr>
                        <td>{{ optionalValue town }}</td>
                        <td>{{ optionalValue postcode }}</td>
                        <td>{{ optionalValue noFixedAbode }}</td>
                    </tr>
                </table>
            {{/addresses}}
            {{^addresses}}
                <p>No Data Held</p>
            {{/addresses}}
        {{/personOnProbation}}
        {{^personOnProbation}}
            <p>No Data Held</p>
        {{/personOnProbation}}

        <h5>Conviction detail</h5>
        {{#convictionDetail}}
            <table class="data-table">
                <tr><td class="data-column-100">Index offence description</td></tr>
                <tr><td>{{ optionalValue indexOffenceDescription }}</td></tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-25">Date of original offence</td></tr>
                <tr><td>{{ optionalValue (formatDate dateOfOriginalOffence) }}</td></tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-100">Sentence description</td></tr>
                <tr><td>{{ optionalValue sentenceDescription }}</td></tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-50">Date of sentence</td>
                    <td class="data-column-25">Length of sentence</td>
                    <td class="data-column-25">Units</td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate dateOfSentence) }}</td>
                    <td>{{ optionalValue lengthOfSentence }}</td>
                    <td>{{ optionalValue lengthOfSentenceUnits }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-50">Sentence expiry</td>
                    <td class="data-column-25">Second sentence length</td>
                    <td class="data-column-25">Units</td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate sentenceExpiryDate) }}</td>
                    <td>{{ optionalValue sentenceSecondLength }}</td>
                    <td>{{ optionalValue sentenceSecondLengthUnits }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Licence expiry</td>
                    <td class="data-column-25">Custodial term</td>
                    <td class="data-column-25">Extended term</td>
                    <td class="data-column-25">Has been reviewed</td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate licenceExpiryDate) }}</td>
                    <td>{{ optionalValue custodialTerm }}</td>
                    <td>{{ optionalValue extendedTerm }}</td>
                    <td>{{ convertBoolean hasBeenReviewed }}</td>
                </tr>
            </table>
        {{/convictionDetail}}
        {{^convictionDetail}}
            <p>No Data Held</p>
        {{/convictionDetail}}
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-20">Alternatives to recall tried</td>
                <td class="data-column-80">Details</td>
            </tr>
            {{#alternativesToRecallTried.selected}}
                <tr>
                    <td>{{ optionalValue value }}</td>
                    <td>{{ optionalValue details }}</td>
                </tr>
            {{/alternativesToRecallTried.selected}}
            {{^alternativesToRecallTried.selected}}
                <tr>
                    <td>No Data Held</td>
                    <td>No Data Held</td>
                </tr>
            {{/alternativesToRecallTried.selected}}
        </table>

        <h5>Licence conditions breached</h5>
        {{#licenceConditionsBreached}}
            <table class="data-table">
                <tr><td class="data-column-20">Standard licence conditions</td></tr>
                <tr><td>{{#standardLicenceConditions.selected}}<li>{{ optionalValue . }}</li>{{/standardLicenceConditions.selected}}{{^standardLicenceConditions.selected}}No Data Held{{/standardLicenceConditions.selected}}</td></tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-100">All options</td></tr>
                {{#standardLicenceConditions.allOptions}}
                    <tr>
                        <td>{{ optionalValue value }}</td>
                        <td>{{ optionalValue text }}</td>
                    </tr>
                {{/standardLicenceConditions.allOptions}}
                {{^standardLicenceConditions.allOptions}}
                    <tr>
                        <td>No Data Held</td>
                        <td>No Data Held</td>
                    </tr>
                {{/standardLicenceConditions.allOptions}}
            </table>
            <br>
            {{#additionalLicenceConditions}}
                {{! selectedOptions are transformed by SubjectAccessRequestService.transformAdditionalLicenceConditions:
                     mainCatCode contains the resolved title }}
                <table class="data-table">
                    <tr><td class="data-column-20">Additional licence conditions</td></tr>
                    <tr><td>{{#selected}}<li>{{ optionalValue . }}</li>{{/selected}}{{#selectedOptions}}<li>{{ optionalValue mainCatCode }}</li>{{/selectedOptions}}{{^selected}}{{^selectedOptions}}No Data Held{{/selectedOptions}}{{/selected}}</td></tr>
                </table>
                <table class="data-table">
                    <tr><td class="data-column-100">All options</td></tr>
                    {{#allOptions}}
                        <tr>
                            <td>{{ optionalValue title }}</td>
                            <td>{{ optionalValue details }}</td>
                        </tr>
                    {{/allOptions}}
                    {{^allOptions}}
                        <tr>
                            <td>No Data Held</td>
                            <td>No Data Held</td>
                        </tr>
                    {{/allOptions}}
                </table>
            {{/additionalLicenceConditions}}
        {{/licenceConditionsBreached}}
        {{^licenceConditionsBreached}}
            <p>No Data Held</p>
        {{/licenceConditionsBreached}}

        <h5>Create and Vary a Licence conditions breached</h5>
        {{#cvlLicenceConditionsBreached}}
            {{#standardLicenceConditions}}
                <table class="data-table">
                    <tr><td class="data-column-20">Standard licence conditions</td></tr>
                    <tr><td>{{#selected}}<li>{{ optionalValue . }}</li>{{/selected}}{{^selected}}No Data Held{{/selected}}</td></tr>
                </table>
                <table class="data-table">
                    <tr><td class="data-column-100">All options</td></tr>
                    {{#allOptions}}
                        <tr><td>{{ optionalValue text }}</td></tr>
                    {{/allOptions}}
                    {{^allOptions}}
                        <tr><td>No Data Held</td></tr>
                    {{/allOptions}}
                </table>
            {{/standardLicenceConditions}}
            <br>
            {{#additionalLicenceConditions}}
                <table class="data-table">
                    <tr><td class="data-column-20">Additional licence conditions</td></tr>
                    <tr><td>{{#selected}}<li>{{ optionalValue . }}</li>{{/selected}}{{^selected}}No Data Held{{/selected}}</td></tr>
                </table>
                <table class="data-table">
                    <tr><td class="data-column-100">All options</td></tr>
                    {{#allOptions}}
                        <tr><td>{{ optionalValue text }}</td></tr>
                    {{/allOptions}}
                    {{^allOptions}}
                        <tr>
                            <td>No Data Held</td>
                            <td>No Data Held</td>
                        </tr>
                    {{/allOptions}}
                </table>
            {{/additionalLicenceConditions}}
            <br>
            {{#bespokeLicenceConditions}}
                <table class="data-table">
                    <tr><td class="data-column-20">Bespoke licence conditions</td></tr>
                    <tr><td>{{#selected}}<li>{{ optionalValue . }}</li>{{/selected}}{{^selected}}No Data Held{{/selected}}</td></tr>
                </table>
                <table class="data-table">
                    <tr><td class="data-column-100">All options</td></tr>
                    {{#allOptions}}
                        <tr><td>{{ optionalValue text }}</td></tr>
                    {{/allOptions}}
                    {{^allOptions}}
                        <tr>
                            <td>No Data Held</td>
                            <td>No Data Held</td>
                        </tr>
                    {{/allOptions}}
                </table>
            {{/bespokeLicenceConditions}}
        {{/cvlLicenceConditionsBreached}}
        {{^cvlLicenceConditionsBreached}}
            <p>No Data Held</p>
        {{/cvlLicenceConditionsBreached}}
        <br>
        <table class="data-table">
            <tr><td class="data-column-100">Additional licence conditions text</td></tr>
            <tr><td>{{ optionalValue additionalLicenceConditionsText }}</td></tr>
        </table>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Vulnerabilities</td>
                <td class="data-column-65">Details</td>
            </tr>
            {{#vulnerabilities.selected}}
                <tr>
                    <td>{{ optionalValue value }}</td>
                    <td>{{ optionalValue details }}</td>
                </tr>
            {{/vulnerabilities.selected}}
            {{^vulnerabilities.selected}}
                <tr>
                    <td>No Data Held</td>
                    <td>No Data Held</td>
                </tr>
            {{/vulnerabilities.selected}}
        </table>
        <br>
        <table class="data-table">
            <tr><td class="data-column-20">Under integrated offender management</td></tr>
            <tr><td>{{ optionalValue isUnderIntegratedOffenderManagement.selected }}</td></tr>
        </table>
        <br>
        <table class="data-table">
            <tr><td class="data-column-100">Index offence details</td></tr>
            <tr><td>{{ optionalValue indexOffenceDetails }}</td></tr>
        </table>
        <table class="data-table">
            <tr><td class="data-column-100">Offence analysis</td></tr>
            <tr><td>{{ optionalValue offenceAnalysis }}</td></tr>
        </table>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Offence data from latest complete assessment</td>
                <td class="data-column-65">Offences match</td>
            </tr>
            <tr>
                <td>{{ convertBoolean offenceDataFromLatestCompleteAssessment }}</td>
                <td>{{ convertBoolean offencesMatch }}</td>
            </tr>
        </table>
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Fixed term additional licence conditions</td>
                <td class="data-column-65">Details</td>
            </tr>
            <tr>
                <td>{{ convertBoolean fixedTermAdditionalLicenceConditions.selected }}</td>
                <td>{{ optionalValue fixedTermAdditionalLicenceConditions.details }}</td>
            </tr>
        </table>
        <br>
        {{#indeterminateOrExtendedSentenceDetails}}
            <table class="data-table">
                <tr>
                    <td class="data-column-35">Indeterminate/extended sentence details</td>
                    <td class="data-column-65">Details</td>
                </tr>
                {{#selected}}
                    <tr>
                        <td>{{ optionalValue value }}</td>
                        <td>{{ optionalValue details }}</td>
                    </tr>
                {{/selected}}
                {{^selected}}
                    <tr>
                        <td>No Data Held</td>
                        <td>No Data Held</td>
                    </tr>
                {{/selected}}
            </table>
        {{/indeterminateOrExtendedSentenceDetails}}
        <br>
        <table class="data-table">
            <tr>
                <td class="data-column-35">Is main address where person can be found</td>
                <td class="data-column-65">Details</td>
            </tr>
            <tr>
                <td>{{ convertBoolean isMainAddressWherePersonCanBeFound.selected }}</td>
                <td>{{ optionalValue isMainAddressWherePersonCanBeFound.details }}</td>
            </tr>
        </table>
        <br>
        {{#whyConsideredRecall}}
            <table class="data-table">
                <tr><td class="data-column-20">Why considered recall</td></tr>
                {{#selected}}
                    <tr><td>{{ optionalValue selected }}</td></tr>
                {{/selected}}
                {{^selected}}
                    <tr><td>No Data Held</td></tr>
                {{/selected}}
            </table>
        {{/whyConsideredRecall}}
        <br>
        <h5>Reasons for no recall</h5>
        {{#reasonsForNoRecall}}
            <table class="data-table">
                <tr><td class="data-column-100">Licence breach</td></tr>
                <tr><td>{{ optionalValue licenceBreach }}</td></tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-100">No recall rationale</td></tr>
                <tr><td>{{ optionalValue noRecallRationale }}</td></tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-100">POP progress made</td></tr>
                <tr><td>{{ optionalValue popProgressMade }}</td></tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-100">POP thoughts</td></tr>
                <tr><td>{{ optionalValue popThoughts }}</td></tr>
            </table>
            <table class="data-table">
                <tr><td class="data-column-100">Future expectations</td></tr>
                <tr><td>{{ optionalValue futureExpectations }}</td></tr>
            </table>
        {{/reasonsForNoRecall}}
        {{^reasonsForNoRecall}}
            <p>No data held</p>
        {{/reasonsForNoRecall}}
        <br>
        <h5>Next appointment (decision not to recall)</h5>
        {{#nextAppointment}}
            {{#howWillAppointmentHappen}}
                <table class="data-table">
